# PriceNexus - Archivo de ejemplo de variables de entorno

# =============================================================================
# CONFIGURACIÓN DE LLMs POR AGENTE
# =============================================================================

# Orchestrator Agent - Modelo para coordinación y planificación
# Opciones:
# - openrouter:xiaomi/mimo-v2-flash (recomendado - buen precio)
# - openrouter:anthropic/claude-3.5-sonnet (mejor rendimiento)
# - openrouter:openai/gpt-4o-mini (bajo costo)
# - ollama:gemma4:e4b (gratis - local)
# - ollama:phi3:mini (gratis - local, más ligero)
PRICE_NEXUS_ORCHESTRATOR_LLM=openrouter:xiaomi/mimo-v2-flash

# Web Searcher Agent - Modelo para búsqueda web
# Debe usar OpenRouter porque depende del server tool `openrouter:web_search`.
# `openrouter:xiaomi/mimo-v2-flash` no funciona bien como Web Searcher en PriceNexus.
# Opción recomendada actual:
# - openrouter:nvidia/nemotron-3-super-120b-a12b:free
PRICE_NEXUS_WEBSEARCHER_LLM=openrouter:nvidia/nemotron-3-super-120b-a12b:free

# Data Extractor Agent - Modelo para extracción de datos HTML
# Puede usar OpenRouter u Ollama.
# Opciones recomendadas actuales:
# - openrouter:xiaomi/mimo-v2-flash
# - ollama:gemma4:e4b
PRICE_NEXUS_DATAEXTRACTOR_LLM=openrouter:xiaomi/mimo-v2-flash

# Dominios permitidos para el Web Searcher (separados por comas)
PRICE_NEXUS_WEBSEARCH_ALLOWED_DOMAINS=.com.ar,.ar

# Cantidad máxima de resultados para el tool de web search
PRICE_NEXUS_WEBSEARCH_MAX_RESULTS=10

# Moneda por defecto cuando una página no la informa explícitamente
PRICE_NEXUS_DEFAULT_CURRENCY=ARS

# =============================================================================
# CONFIGURACIÓN DE API KEYS
# =============================================================================

# OpenRouter API Key
# Obtén tu API key en: https://openrouter.ai/keys
# Usada para modelos de OpenRouter (xiaomi/mimo-v2-flash, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# NOTA: OpenRouter usa la API compatibe con OpenAI, pero la variable de entorno
# es OPENROUTER_API_KEY para distinguirla claramente

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================

# Ruta de la base de datos SQLite (opcional, por defecto es "prices.db")
# DB_PATH=prices.db

# =============================================================================
# CONFIGURACIÓN DE LOGGING (OPCIONAL)
# =============================================================================

# Nivel de logging: debug, info, warn, error
# LOG_LEVEL=info

# =============================================================================
# EJEMPLOS DE CONFIGURACIÓN ALTERNATIVAS
# =============================================================================

# Ejemplo 1: Mix recomendado para etapa actual
# PRICE_NEXUS_ORCHESTRATOR_LLM=openrouter:xiaomi/mimo-v2-flash
# PRICE_NEXUS_WEBSEARCHER_LLM=openrouter:nvidia/nemotron-3-super-120b-a12b:free
# PRICE_NEXUS_DATAEXTRACTOR_LLM=openrouter:xiaomi/mimo-v2-flash

# Ejemplo 2: Máximo rendimiento (todo vía API)
# PRICE_NEXUS_ORCHESTRATOR_LLM=openrouter:anthropic/claude-3.5-sonnet
# PRICE_NEXUS_WEBSEARCHER_LLM=openrouter:nvidia/nemotron-3-super-120b-a12b:free
# PRICE_NEXUS_DATAEXTRACTOR_LLM=openrouter:xiaomi/mimo-v2-flash

# =============================================================================
# NOTAS
# =============================================================================

# 1. Copia este archivo a .env y reemplaza los valores con los tuyos
# 2. No commitees el archivo .env (está en .gitignore)
# 3. Los valores de .env sobrescriben los valores por defecto
# 4. Para usar Ollama local, asegúrate de tener ollama corriendo:
#    - Iniciar servidor: ollama serve
#    - Ver modelos: ollama list
#    - Descargar modelo: ollama pull gemma4:e4b
